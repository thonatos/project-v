# i18n-studio 同步脚本凭据（pull/push）
# 复制为 .env 并填入实际值；.env 已被 git 忽略，请勿提交。

# studio 服务地址（不带末尾斜杠）
STUDIO_BASE_URL=http://localhost:5173

# 承载界面文案的 namespace slug（pull/push 的目标）
STUDIO_NAMESPACE=studio-ui

# 该 namespace 的 write scope token（在 dashboard token 管理界面创建）
# push 脚本用它向上面的 namespace 写入文案；pull 走公开 snapshot，无需 token。
STUDIO_WRITE_TOKEN=
