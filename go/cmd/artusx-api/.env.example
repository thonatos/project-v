# artusx-api (Go) 环境变量示例
# 复制为 .env 后填入真实值：cp .env.example .env
# 服务启动时会自动加载同目录下的 .env（不覆盖已存在的真实环境变量）。
# 注意：.env 已被 .gitignore 忽略，切勿提交真实凭据。

# 监听端口，缺省 7001。并存期本地同时跑 Node 版时，给其一改端口（如 7002）。
PORT=7001

# /webhook/* 的 query token 校验值（?token=xxx 需与此一致，否则 403）
WEBHOOK_AUTH_TOKEN=change-me

# Telegram Bot API token（BotFather 申请）。
# 前提：将该 bot 加入下方 channel 并授予发帖权限（管理员）。
BOT_AUTH_TOKEN=123456:ABC-your-bot-token

# 推送目标 channel（可用 @channelusername 或数字 chat id）
# madrid / info 接口 → INFO；idea 接口 → IDEA
TELEGRAM_CHANNEL_INFO=@your_info_channel
TELEGRAM_CHANNEL_IDEA=@your_idea_channel
